# TEMPLATE ONLY — do NOT put real passwords here.
# Create the real secret with kubectl (see k8sSetupNote.text):
#
#   kubectl create secret generic todo-secrets -n todo \
#     --from-literal=DB_USER=root \
#     --from-literal=DB_PASSWORD=your_password \
#     --from-literal=JWT_SECRET=your_jwt_secret
#
apiVersion: v1
kind: Secret
metadata:
  name: todo-secrets
  namespace: todo
type: Opaque
stringData:
  DB_USER: root
  DB_PASSWORD: change_me
  JWT_SECRET: change_me
